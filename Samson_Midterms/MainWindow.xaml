<Window x:Class="List3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="450" Width="950">

    <Grid Background="Beige">

        <Label Content="Shopping Cart System"
               HorizontalAlignment="Center"
               VerticalAlignment="Top"
               Margin="0,10,0,0"
               FontSize="20"/>

        <DataGrid Name="ItemGrid"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Top"
                  Margin="22,62,0,0"
                  Height="252"
                  Width="420"
                  AutoGenerateColumns="False"
                  SelectionChanged="ItemGrid_SelectionChanged">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ItemID}" Width="50"/>
                <DataGridTextColumn Header="Name" Binding="{Binding ItemName}" Width="120"/>
                <DataGridTextColumn Header="Description" Binding="{Binding ItemDescription}" Width="180"/>
                <DataGridTextColumn Header="Price" Binding="{Binding ItemPrice}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <DataGrid Name="CartGrid"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  Margin="0,62,22,0"
                  Height="252"
                  Width="420"
                  AutoGenerateColumns="False">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ItemID}" Width="50"/>
                <DataGridTextColumn Header="Name" Binding="{Binding ItemName}" Width="120"/>
                <DataGridTextColumn Header="Description" Binding="{Binding ItemDescription}" Width="180"/>
                <DataGridTextColumn Header="Price" Binding="{Binding ItemPrice}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="10">

            <StackPanel Margin="5">
                <Label Content="ID"/>
                <TextBox Name="ItemID" Width="40"/>
            </StackPanel>

            <StackPanel Margin="5">
                <Label Content="Name"/>
                <TextBox Name="ItemName" Width="100"/>
            </StackPanel>

            <StackPanel Margin="5">
                <Label Content="Description"/>
                <TextBox Name="ItemDescription" Width="100"/>
            </StackPanel>

            <StackPanel Margin="5">
                <Label Content="Price"/>
                <TextBox Name="ItemPrice" Width="50"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Bottom"
                        Margin="0,25,0,0">

                <Button Content="Create Item"
                        Width="80"
                        Height="23"
                        Margin="5"
                        Click="AddButtonClick"
                        Background="Green"
                        Foreground="White"/>

                <Button Content="Remove"
                        Width="62"
                        Height="23"
                        Margin="5"
                        Click="RemoveButtonClick"
                        Background="Red"
                        Foreground="White"/>

                <Button Content="Clear"
                        Width="51"
                        Height="23"
                        Margin="5"
                        Click="ClearButtonClick"/>

                <Button Content="Add to Cart"
                        Width="80"
                        Height="23"
                        Margin="5"
                        Click="AddToCartButtonClick"
                        Background="Orange"/>

                <Button Content="Remove From Cart"
                        Width="115"
                        Height="23"
                        Margin="5"
                        Click="RemoveFromCartButtonClick"
                        Background="DarkRed"
                        Foreground="White"/>

            </StackPanel>

        </StackPanel>

    </Grid>
</Window>